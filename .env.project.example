# HoweverUnsloth project customization profile
# Copy this file to .env.project and export values before launch:
#   set -a; source .env.project; set +a

# Branding
HOWEVER_PROJECT_NAME=howeverunsloth
HOWEVER_PROJECT_DISPLAY_NAME=HoweverUnsloth Studio
HOWEVER_PROJECT_DESCRIPTION=面向私有化部署的本地模型训练与推理平台
HOWEVER_REPO_DESCRIPTION=私有化模型训练、推理与数据配方平台（基于 Unsloth 二次工程化）
HOWEVER_GITHUB_TOPICS=llm,finetuning,inference,ollama,local-llm,however

# Service endpoints (replace with your own addresses)
HOWEVER_DATABASE_URL=sqlite:///~/.howeverunsloth/studio/studio.db
HOWEVER_REDIS_URL=redis://127.0.0.1:6379/0
HOWEVER_OLLAMA_BASE_URL=http://127.0.0.1:11434
HOWEVER_OPENAI_BASE_URL=https://api.openai.com/v1
HOWEVER_VLLM_BASE_URL=http://127.0.0.1:8000
HOWEVER_PROVIDER_DEFAULT=ollama
HOWEVER_ALLOW_RUNTIME_CONFIG_UPDATE=0
HOWEVER_QUOTA_REQ_PER_MIN=120
HOWEVER_QUOTA_CONCURRENT_JOBS=4
HOWEVER_QUOTA_TOKENS_PER_DAY=2000000

# Optional auth / model runtime examples
HF_TOKEN=
OPENAI_API_KEY=
WANDB_API_KEY=
